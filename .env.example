# Sky-History Configuration
# Copy this file to .env and adjust values

# PostgreSQL connection string
# For Docker Compose, leave commented out (uses internal networking).
# For local development against a remote PostgreSQL:
#DATABASE_URL=postgres://skyhistory:skyhistory@skyhistory-db:5432/skyhistory?sslmode=disable

# PostgreSQL password (only used by docker-compose for the db container)
POSTGRES_PASSWORD=skyhistory

# GitHub personal access token (optional, recommended for higher rate limits)
GITHUB_TOKEN=

# GitHub repository to poll for releases
GITHUB_REPO=adsblol/globe_history_2026

# How often to check for new releases
POLL_INTERVAL=1h

# Number of days to backfill on first run (0 = only new releases)
BACKFILL_DAYS=0

# Number of concurrent file parser workers
PARSE_WORKERS=4

# Directory for downloaded release files (default: OS temp directory)
# TEMP_DIR=D:\skyhistory-data

# Keep downloaded files on disk to avoid re-downloading during development.
# Set to true to cache; files are reused if they already exist for a release tag.
KEEP_DOWNLOADS=false

# Custom tar1090/ultrafeeder URLs (comma-separated base URLs)
# Example: http://192.168.1.100:8080/tar1090,http://myreadsb.local
ULTRAFEEDER_URLS=

# Port the frontend is exposed on
FRONTEND_PORT=8080
